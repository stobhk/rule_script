#!name = Surge Pro
#!desc=Surge 订阅日期面板
#!arguments = "licensesDate:2025-11-17"
#!arguments-desc = 请严格按照 YYYY-MM-DD 格式填入授权到期日


[Panel]
SurgePro = script-name=licensesCheck,update-interval=1

[Script]
licensesCheck =script-path=https://raw.githubusercontent.com/stobhk/rule_script/refs/heads/main/panel/surge/licensesCheck.js,type=generic,argument=licensesDate={{{licensesDate}}}